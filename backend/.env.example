# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chyrralon
DB_USER=change_me
DB_PASSWORD=change_me

# Application Configuration
APP_ENV=development
APP_DEBUG=true

# API Configuration
API_VERSION=v1

# Base path for subdirectory deployments (e.g. /chyrralon)
APP_BASE_PATH=/chyrralon
CORS_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost,http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=debug

# WebHatchery Auth (shared JWT)
JWT_SECRET=your_webhatchery_jwt_secret
WEB_HATCHERY_LOGIN_URL=http://127.0.0.1/auth/login
